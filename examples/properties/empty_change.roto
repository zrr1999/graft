// Pattern: structural predicate over the path set.
//
// `app.changed_paths()` is the path set of the change; the property holds
// when no path is touched. Pure structural; no command execution.

fn empty_change(app: Application) -> Property {
    property(
        [
            app.changed_paths().any_match(["**"]).failure(),
        ],
        "the change touches no paths",
        Severity.Blocking,
        [],
    )
}
