// Pattern: command oracle on `app.target()`.
//
// `call(argv, tree)` constructs a deferred Run node anchored at the given
// tree. Multiple probes that reference the same Run share one execution
// (deduplicated by canonical execution key).

fn cargo_tests_pass(app: Application) -> Property {
    let run = call(["cargo", "test", "--all-targets"], app.target());

    property(
        [
            run.exit_code_is(0).success(),
        ],
        "cargo test --all-targets passes on the target tree",
        Severity.Blocking,
        [],
    )
}
